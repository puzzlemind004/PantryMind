# Configuration de production — à copier en .env.production sur le serveur.
# Ce fichier ne doit JAMAIS contenir de vraies valeurs dans le dépôt.
#
# Toutes les variables sont préfixées COOKING_ : Docker Compose donne la
# priorité aux variables du shell sur --env-file, et un serveur mutualisé
# peut exporter des DB_USER/APP_KEY d'autres applications (vécu). Le
# préfixe élimine ce risque.

# Clé applicative AdonisJS (générer avec : openssl rand -base64 32)
COOKING_APP_KEY=

# Adresse publique de l'application
# - avec domaine : COOKING_SITE_ADDRESS=cooking.mondomaine.fr et COOKING_APP_URL=https://cooking.mondomaine.fr
# - sans domaine (IP) : COOKING_SITE_ADDRESS=:80 et COOKING_APP_URL=http://IP_DU_VPS
COOKING_SITE_ADDRESS=
COOKING_APP_URL=

# Liaison des ports du conteneur web (défaut : 80 et 443 sur toutes les
# interfaces). Derrière un reverse proxy natif existant, lier en local :
# COOKING_WEB_BIND=127.0.0.1:8080
# COOKING_WEB_TLS_BIND=127.0.0.1:8443
# et mettre COOKING_SITE_ADDRESS=:80 (le TLS est géré par le proxy natif).
#COOKING_WEB_BIND=
#COOKING_WEB_TLS_BIND=

# Base de données (le conteneur postgres est initialisé avec ces valeurs)
COOKING_DB_USER=cooking
COOKING_DB_PASSWORD=
COOKING_DB_DATABASE=cooking

# Web Push — générer avec : npx web-push generate-vapid-keys
# Laisser vide pour désactiver les notifications.
COOKING_VAPID_PUBLIC_KEY=
COOKING_VAPID_PRIVATE_KEY=
COOKING_VAPID_SUBJECT=mailto:contact@puzzlemind.fr
