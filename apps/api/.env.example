# Node
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=
APP_URL=http://${HOST}:${PORT}

# Session
SESSION_DRIVER=cookie

# Database (docker compose à la racine du dépôt)
DB_HOST=127.0.0.1
DB_PORT=5434
DB_USER=cooking
DB_PASSWORD=cooking
DB_DATABASE=cooking

